
<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Personal Leo</title>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<style>

body{
margin:0;
font-family:Segoe UI;
background:#0f172a;
color:white;
}

.center{
display:flex;
justify-content:center;
align-items:center;
height:100vh;
}

.login{
background:#020617;
padding:40px;
border-radius:10px;
width:320px;
text-align:center;
}

input{
width:100%;
padding:10px;
margin:6px 0;
border-radius:6px;
border:none;
}

button{
padding:10px;
border:none;
border-radius:6px;
background:#2563eb;
color:white;
cursor:pointer;
margin-top:5px;
}

button:hover{
background:#1d4ed8;
}

.sidebar{
position:fixed;
left:0;
top:0;
width:220px;
height:100%;
background:#020617;
padding-top:20px;
}

.sidebar h2{
text-align:center;
}

.sidebar button{
width:100%;
background:none;
padding:15px;
text-align:left;
color:white;
}

.sidebar button:hover{
background:#1e293b;
}

.main{
margin-left:220px;
padding:30px;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
}

.card{
background:#020617;
padding:20px;
border-radius:10px;
margin-bottom:15px;
}

table{
width:100%;
border-collapse:collapse;
margin-top:20px;
}

th{
background:#1e293b;
padding:10px;
}

td{
padding:8px;
border-bottom:1px solid #1e293b;
text-align:center;
}

.hidden{
display:none;
}

</style>
</head>

<body>

<!-- LOGIN -->

<div id="loginTela" class="center">

<div class="login">

<h2 onclick="abrirAdmin()" style="cursor:pointer">LOGIN</h2>

<input id="loginEmail" placeholder="Email">
<input id="loginSenha" type="password" placeholder="Senha">

<button onclick="login()">Entrar</button>
<button onclick="mostrarCadastro()">Criar conta</button>

</div>

</div>

<!-- CADASTRO -->

<div id="cadastroTela" class="center hidden">

<div class="login">

<h2>Cadastrar</h2>

<input id="cadNome" placeholder="Nome">
<input id="cadEmail" placeholder="Email">
<input id="cadSenha" placeholder="Senha">

<button onclick="cadastrar()">Cadastrar</button>
<button onclick="voltar()">Voltar</button>

</div>

</div>

<!-- MENU ADMIN -->

<div id="app" class="hidden">

<div class="sidebar">

<h2>Personal Leo</h2>

<button onclick="dashboard()">Dashboard</button>
<button onclick="verAlunos()">Alunos</button>
<button onclick="verTreinos()">Treinos</button>
<button onclick="logout()">Sair</button>

</div>

<div class="main">

<div id="conteudo"></div>

</div>

</div>

<!-- AREA ALUNO -->

<div id="alunoTela" class="hidden main">

<h2 id="nomeAluno"></h2>

<input type="file" id="comprovante">

<button onclick="enviarComprovante()">Enviar comprovante</button>

<div id="status"></div>

<div id="treinosAluno"></div>

<button onclick="logout()">Sair</button>

</div>

<script>

const SENHA_ADMIN="zinca26"

let usuarios=JSON.parse(localStorage.getItem("usuarios"))||[]
let treinos=JSON.parse(localStorage.getItem("treinos"))||[]

let usuarioAtual=null

function salvar(){
localStorage.setItem("usuarios",JSON.stringify(usuarios))
localStorage.setItem("treinos",JSON.stringify(treinos))
}

/* LOGIN */

function login(){

let u=usuarios.find(x=>x.email==loginEmail.value && x.senha==loginSenha.value)

if(!u){
alert("Login inválido")
return
}

usuarioAtual=usuarios.find(x=>x.email==u.email)

loginTela.classList.add("hidden")
alunoTela.classList.remove("hidden")

nomeAluno.innerHTML="Olá "+usuarioAtual.nome

statusUsuario()
mostrarTreinosAluno()

}

/* ADMIN */

function abrirAdmin(){

let senha=prompt("Senha admin")

if(senha!=SENHA_ADMIN) return

loginTela.classList.add("hidden")
app.classList.remove("hidden")

dashboard()

}

/* CADASTRO */

function cadastrar(){

usuarios.push({
nome:cadNome.value,
email:cadEmail.value,
senha:cadSenha.value,
comprovante:null,
liberado:false
})

salvar()

alert("Conta criada")

voltar()

}

function mostrarCadastro(){
loginTela.classList.add("hidden")
cadastroTela.classList.remove("hidden")
}

function voltar(){
cadastroTela.classList.add("hidden")
loginTela.classList.remove("hidden")
}

/* DASHBOARD */

function dashboard(){

conteudo.innerHTML=`

<h1>Dashboard</h1>

<div class="cards">

<div class="card">
Alunos
<h2>${usuarios.length}</h2>
</div>

<div class="card">
Pagos
<h2>${usuarios.filter(x=>x.liberado).length}</h2>
</div>

<div class="card">
Treinos
<h2>${treinos.length}</h2>
</div>

</div>

`

}

/* COMPROVANTE */

function verComprovante(img){
let w=window.open("")
w.document.write(`<img src="${img}" style="width:100%">`)
}

/* ALUNOS */

function verAlunos(){

let html=`

<h1>Alunos</h1>

<table>

<tr>
<th>Nome</th>
<th>Email</th>
<th>Comprovante</th>
<th>Status</th>
<th>Ações</th>
</tr>

`

usuarios.forEach((u,i)=>{

html+=`

<tr>

<td>${u.nome}</td>
<td>${u.email}</td>

<td>
${u.comprovante
? `<img src="${u.comprovante}" width="70" style="cursor:pointer" onclick="verComprovante('${u.comprovante}')">`
: "Não enviado"}
</td>

<td>
${u.liberado ? "Pago" : "Bloqueado"}
</td>

<td>

<button onclick="toggleAluno(${i})">
${u.liberado ? "Bloquear" : "Liberar"}
</button>

<button onclick="apagarAluno(${i})">
Apagar
</button>

</td>

</tr>

`

})

html+="</table>"

conteudo.innerHTML=html

}

function toggleAluno(i){

usuarios[i].liberado=!usuarios[i].liberado

salvar()

verAlunos()

}

function apagarAluno(i){

if(confirm("Apagar aluno?")){

usuarios.splice(i,1)

salvar()

verAlunos()

}

}

/* TREINOS */

function verTreinos(){

let html=`<h1>Treinos</h1>

<button onclick="criarTreino()">Criar treino</button>

`

treinos.forEach((t,i)=>{

html+=`

<div class="card">

<h3>${t.nome}</h3>

<p>${t.explicacao}</p>

<b>Preço: R$ ${t.preco}</b>

<br><br>

<button onclick="verTreino(${i})">Ver</button>
<button onclick="apagarTreino(${i})">Apagar</button>

</div>

`

})

conteudo.innerHTML=html

}

function criarTreino(){

let nome=prompt("Nome treino")
let explicacao=prompt("Explicação")
let preco=prompt("Preço")

let dias={}

for(let d of ["Segunda","Terça","Quarta","Quinta","Sexta"]){

let lista=[]

while(true){

let ex=prompt(d+" exercício (cancelar para parar)")

if(!ex) break

let s=prompt("Séries")
let r=prompt("Reps")

lista.push({ex,s,r})

}

dias[d]=lista

}

treinos.push({nome,explicacao,preco,dias})

salvar()

verTreinos()

}

function apagarTreino(i){

if(confirm("Apagar treino?")){

treinos.splice(i,1)

salvar()

verTreinos()

}

}

/* STATUS */

function statusUsuario(){

if(!usuarioAtual.comprovante)
status.innerHTML="Envie comprovante"

else if(!usuarioAtual.liberado)
status.innerHTML="Aguardando liberação"

else
status.innerHTML="Pagamento aprovado"

}

/* COMPROVANTE */

function enviarComprovante(){

let file=comprovante.files[0]

let reader=new FileReader()

reader.onload=function(e){

let usuario=usuarios.find(u=>u.email==usuarioAtual.email)

usuario.comprovante=e.target.result

usuarioAtual=usuario

salvar()

statusUsuario()

alert("Comprovante enviado")

}

reader.readAsDataURL(file)

}

/* TREINOS ALUNO */

function mostrarTreinosAluno(){

let html="<h2>Treinos disponíveis</h2>"

treinos.forEach((t,i)=>{

html+=`

<div class="card">

<h3>${t.nome}</h3>

<p>${t.explicacao}</p>

<b>Preço: R$ ${t.preco}</b>

<br><br>

`

if(usuarioAtual.liberado){

html+=`<button onclick="pdf(${i})">Baixar PDF</button>`

}else{

html+=`<p style="color:#f87171">Treino bloqueado até pagamento</p>`

}

html+=`</div>`

})

treinosAluno.innerHTML=html

}

/* PDF TABELA */

function pdf(i){

if(!usuarioAtual.liberado){

alert("Treino bloqueado")

return

}

const {jsPDF}=window.jspdf

let doc=new jsPDF()

let t=treinos[i]

let y=20

doc.setFontSize(18)
doc.text(t.nome,20,y)

y+=10

for(let d in t.dias){

doc.setFontSize(14)
doc.text(d,20,y)

y+=6

doc.setFontSize(12)

doc.text("Exercício",20,y)
doc.text("Séries",120,y)
doc.text("Reps",160,y)

y+=4

doc.line(20,y,190,y)

y+=6

t.dias[d].forEach(e=>{

doc.text(e.ex,20,y)
doc.text(String(e.s),120,y)
doc.text(String(e.r),160,y)

y+=6

})

y+=8

}

doc.save("treino.pdf")

}

function logout(){
location.reload()
}

</script>

</body>
</html>
```
